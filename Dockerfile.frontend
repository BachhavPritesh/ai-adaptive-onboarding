# Build stage
FROM node:18-alpine AS builder

WORKDIR /app

# Copy package files
COPY onboard-ai/package*.json ./

# Install dependencies
RUN npm ci

# Copy frontend source code
COPY onboard-ai/ .

# Build the app
RUN npm run build

# Production stage
FROM nginx:alpine

# Copy built assets
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx config
COPY docker/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
